    {
      "id": 1,
      "question": "If a curve crosses the x-axis at x=c between a and b, the total area is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "|∫_a^c y dx| + |∫_c^b y dx|",
        "B": "∫_a^b y dx",
        "C": "∫_a^c y dx - ∫_c^b y dx",
        "D": "0"
      },
      "answer": "A",
      "pyq": false
    },
