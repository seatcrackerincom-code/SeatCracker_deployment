    {
      "id": 1,
      "question": "Matrix multiplication is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Associative but generally not commutative",
        "B": "Commutative",
        "C": "Neither associative nor commutative",
        "D": "Always commutative for square matrices"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "If A is a square matrix of order n, then |kA| = ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "kⁿ |A|",
        "B": "k |A|",
        "C": "nᵏ |A|",
        "D": "k² |A|"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "Which of the following is true for any two square matrices A and B of the same order?",
