  "questions": [
    {
      "id": 1,
      "question": "In translation of axes without rotation, if origin is shifted to (h, k), the new coordinates (X, Y) are related to old coordinates (x, y) by ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "x = X + h, y = Y + k",
        "B": "X = x + h, Y = y + k",
        "C": "x = X - h, y = Y - k",
        "D": "X = h - x, Y = k - y"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "If equation is f(x, y) = 0 and origin is shifted to (h, k), the transformed equation is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "f(X + h, Y + k) = 0",
        "B": "f(X - h, Y - k) = 0",
        "C": "f(X, Y) = 0",
        "D": "f(x - h, y - k) = 0"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "In rotation of axes by an angle θ without shifting origin, the new coordinates (X, Y) relate to old (x, y) as x = ______.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "X cos θ - Y sin θ",
        "B": "X cos θ + Y sin θ",
        "C": "X sin θ + Y cos θ",
        "D": "X sin θ - Y cos θ"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 4,
      "question": "Similarly, the relationship for y is y = ______.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "X sin θ + Y cos θ",
        "B": "X sin θ - Y cos θ",
        "C": "X cos θ - Y sin θ",
        "D": "X cos θ + Y sin θ"
      },
      "answer": "A",
      "pyq": false
    },
    {
