  "questions": [
    {
      "id": 1,
      "question": "The equation x² + y² + 2gx + 2fy + c = 0 represents a point circle if ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "g² + f² - c = 0",
        "B": "g² + f² - c > 0",
        "C": "c = 0",
        "D": "g = f = 0"
      },
      "answer": "A"
    },
    {
      "id": 2,
      "question": "The power of a point P(x₁, y₁) with respect to circle S = 0 is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "S₁₁",
        "B": "√S₁₁",
        "C": "0",
        "D": "Radius"
      },
      "answer": "A"
    },
    {
      "id": 3,
      "question": "The condition for the line y = mx + c to be a tangent to the circle x² + y² = a² is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "c² = a²(1 + m²)",
        "B": "c = am",
        "C": "c² = a² / (1 + m²)",
        "D": "c = a"
      },
      "answer": "A"
    },
    {
      "id": 4,
      "question": "The length of the tangent from external point P(x₁, y₁) to circle S = 0 is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "√S₁₁",
        "B": "S₁₁",
        "C": "2√S₁₁",
        "D": "Radius"
      },
      "answer": "A"
    },
    {
      "id": 5,
      "question": "Parametric equations of the circle (x-h)² + (y-k)² = r² are ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
