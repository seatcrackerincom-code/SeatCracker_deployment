  ],
  "questions": [
    {
      "id": 1,
      "question": "For 1/((x-1)(x-2)), the partial fraction decomposition takes the form ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "A/(x-1) + B/(x-2)",
        "B": "(Ax+B)/((x-1)(x-2))",
        "C": "A/(x-1) + Bx/(x-2)",
        "D": "A/(x-1)² + B/(x-2)"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "In the decomposition P(x)/((x-a)(x-b)) = A/(x-a) + B/(x-b), A can be found quickly using the ______ by setting x = a.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Cover-up method (Heaviside)",
        "B": "Taylor expansion",
        "C": "Integration by parts",
        "D": "Binomial Theorem"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "If Q(x) has a repeated linear factor (ax + b)^k, it corresponds to a sum of ______ partial fractions.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "k",
        "B": "k-1",
        "C": "1",
        "D": "k+1"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 4,
      "question": "The partial fractions for repeated linear roots 1/(x-a)³ will be: A/(x-a) + B/(x-a)² + ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "C/(x-a)³",
        "B": "C/(x-a)",
        "C": "(Cx+D)/(x-a)³",
        "D": "1/(x-a)³"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 5,
      "question": "If Q(x) contains a non-repeated irreducible quadratic factor (ax² + bx + c), the corresponding partial fraction is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(Ax + B) / (ax² + bx + c)",
        "B": "A / (ax² + bx + c)",
        "C": "(Ax² + B) / (ax² + bx + c)",
        "D": "A / (ax+b) + B / (cx+d)"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 6,
      "question": "For a rational function like (x² + 1) / (x³ + 1), the first step is to factorize the denominator logic entirely into ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Linear and irreducible quadratic factors over real numbers",
        "B": "Only linear factors",
        "C": "Taylor series parts",
        "D": "Monomials"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 7,
      "question": "In the decomposition of x / ((x-1)(x²+1)), the correct form is A/(x-1) + ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(Bx + C)/(x²+1)",
        "B": "B/(x²+1)",
        "C": "(B+x)/(x²+1)",
        "D": "C/(x-1)²"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 8,
      "question": "If the denominator contains a repeated irreducible quadratic factor (ax²+bx+c)², the decomposition includes (Ax+B)/(ax²+bx+c) + ______.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(Cx+D)/(ax²+bx+c)²",
        "B": "C/(ax²+bx+c)²",
        "C": "(Cx²+Dx+E)/(ax²+bx+c)²",
        "D": "C/(ax²+bx+c)"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 9,
      "question": "To resolve (x³ + 1) / (x² - 1) into partial fractions, the very first step is ______.",
