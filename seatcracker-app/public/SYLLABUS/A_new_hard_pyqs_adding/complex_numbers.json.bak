    {
      "id": 1,
      "question": "If z₁ and z₂ are complex numbers, then |z₁z₂| is equal to:",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "|z₁||z₂|",
        "B": "|z₁| + |z₂|",
        "C": "|z₁| - |z₂|",
        "D": "|z₁|/|z₂|"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "Triangle Inequality states that |z₁ + z₂| is ______ |z₁| + |z₂|.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "≤",
        "B": "≥",
        "C": "=",
        "D": "<"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "The argument of z = x + iy, denoted as arg(z), is the angle θ such that:",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "tan θ = y/x",
