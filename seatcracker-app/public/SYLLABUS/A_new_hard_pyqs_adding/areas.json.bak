  ],
  "questions": [
    {
      "id": 1,
      "question": "If f(x) ≤ 0 for all x in [a, b], then the definite integral ∫ f(x) dx from a to b yields a negative value. The actual geometric area is obtained by ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "|∫ f(x) dx| or -∫ f(x) dx",
        "B": "∫ f(x) dx directly",
        "C": "Zero",
        "D": "∫ |x| f(x) dx"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "If the curve y = f(x) crosses the x-axis at x = c (a < c < b), to find the total area, the integral must be broken into ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "|∫ from a to c f(x)dx| + |∫ from c to b f(x)dx|",
        "B": "∫ from a to b f(x)dx directly",
        "C": "∫ from a to b |f(x)|dx",
        "D": "Both A and C are correct formulations"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "The area bounded by a curve x = g(y), the y-axis, and abscissae y = c and y = d is given by ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "∫ from c to d g(y) dy",
        "B": "∫ from c to d g(x) dx",
        "C": "∫ from c to d g'(y) dy",
        "D": "g(d) - g(c)"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 4,
      "question": "To find the area between two curves y = f(x) and y = g(x) where f(x) ≥ g(x) from x=a to x=b, the integral is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "∫ from a to b [f(x) - g(x)] dx",
        "B": "∫ from a to b [f(x) + g(x)] dx",
        "C": "∫ from a to b [f(x) * g(x)] dx",
        "D": "∫ from a to b [f(x) / g(x)] dx"
      },
      "answer": "A",
      "pyq": false
    },
    {
