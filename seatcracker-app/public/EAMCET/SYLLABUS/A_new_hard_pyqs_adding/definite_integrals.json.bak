  "questions": [
    {
      "id": 1,
      "question": "∫_a^b f(x) dx = ∫_a^c f(x) dx + ∫_c^b f(x) dx is valid for ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Any real c",
        "B": "Only c between a and b",
        "C": "Only positive c",
        "D": "c = 0"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "Property: ∫_a^b f(x) dx = ∫_a^b f(a+b-x) dx.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "True",
        "B": "False",
        "C": "Only if f is even",
        "D": "Only if b > a"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
