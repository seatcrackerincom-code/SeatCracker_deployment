      "id": 1,
      "question": "According to the product rule, d/dx [u(x)v(x)] = ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "u v' + v u'",
        "B": "u' v'",
        "C": "u v' - v u'",
        "D": "(u v' + v u') / v²"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "According to the quotient rule, d/dx [u/v] = ______.",
