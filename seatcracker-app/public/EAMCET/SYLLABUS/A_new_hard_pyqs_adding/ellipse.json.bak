    {
      "id": 51,
      "question": "If the ellipse x²/a² + y²/b² = 1 passes through (1,2) and (2,1), then a² + b² = ?",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "10",
        "B": "5",
        "C": "a²b²=a²+b²",
        "D": "cannot determine"
      },
      "answer": "C",
      "pyq": true,
      "tag": "pyq"
    },
    {
      "id": 52,
      "question": "Condition for y = mx + c to be tangent to x²/a²+y²/b²=1 is?",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "c² = a²m² + b²",
