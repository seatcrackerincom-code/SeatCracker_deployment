        "C": "c = am",
        "D": "b² = a²m + c"
      },
      "answer": "A",
      "pyq": true,
      "tag": "pyq"
    },
    {
      "id": 53,
      "question": "The equation of director circle of ellipse x²/a²+y²/b²=1 is?",
