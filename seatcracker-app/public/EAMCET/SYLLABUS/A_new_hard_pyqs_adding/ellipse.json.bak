    {
      "id": 1,
      "question": "The directrices of the ellipse x²/a² + y²/b² = 1 are ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "x = ±a/e",
        "B": "x = ±ae",
        "C": "y = ±a/e",
        "D": "x = ±a"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "The equation of auxiliary circle of ellipse x²/a² + y²/b² = 1 is ______.",
