  "questions": [
    {
      "id": 1,
      "question": "For any two events A and B, P(A ∪ B) is equal to:",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "P(A) + P(B) - P(A ∩ B)",
        "B": "P(A) + P(B)",
        "C": "P(A)P(B)",
        "D": "P(A) - P(B)"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "If P(A) = 1/2 and P(B) = 1/3, and A and B are independent, then P(A ∩ B) is:",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "1/6",
        "B": "5/6",
        "C": "1/5",
        "D": "1"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "Conditional probability of A given B is denoted as P(A|B) and is equal to:",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "P(A ∩ B) / P(B)",
        "B": "P(A ∩ B) / P(A)",
