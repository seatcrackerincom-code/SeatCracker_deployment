  "questions": [
    {
      "id": 1,
      "question": "For the quadratic expression ax² + bx + c, the y-coordinate of the vertex is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "-D / 4a",
        "B": "-b / 2a",
        "C": "D / 4a",
        "D": "b / 2a"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "If one root of ax² + bx + c = 0 is reciprocal of the other, then ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "a = c",
        "B": "a = b",
        "C": "b = c",
        "D": "a + c = 0"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "If the roots of ax² + bx + c = 0 are equal in magnitude but opposite in sign, then ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "b = 0",
        "B": "a = 0",
        "C": "c = 0",
        "D": "a = c"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 4,
      "question": "If α, β are roots of ax² + bx + c = 0, then the value of α² + β² is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(b² - 2ac) / a²",
        "B": "b² / a²",
