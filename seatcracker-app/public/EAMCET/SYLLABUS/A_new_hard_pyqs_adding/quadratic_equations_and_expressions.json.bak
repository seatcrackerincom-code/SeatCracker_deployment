        "D": "c²/a²"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 5,
      "question": "The maximum value of the expression -ax² + bx + c (a > 0) occurs at x = ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
