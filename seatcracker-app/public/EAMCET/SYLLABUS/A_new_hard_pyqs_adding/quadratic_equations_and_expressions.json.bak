        "D": "0"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 6,
      "question": "Two quadratic equations a1x² + b1x + c1 = 0 and a2x² + b2x + c2 = 0 have both roots common if ______.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "a1/a2 = b1/b2 = c1/c2",
        "B": "a1=a2, b1=b2",
        "C": "c1=c2",
        "D": "a1c1 = a2c2"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 7,
      "question": "The condition for common root between a1x² + b1x + c1 = 0 and a2x² + b2x + c2 = 0 is denoted by a ______ relation.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(c1a2-c2a1)² = (a1b2-a2b1)(b1c2-b2c1)",
        "B": "a1b2 = b1a2",
        "C": "c1/c2 = a1/a2",
        "D": "Check discriminants"
      },
      "answer": "A",
      "pyq": false
    },
