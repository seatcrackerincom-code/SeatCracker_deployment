  "questions": [
    {
      "id": 1,
      "question": "If n is a fraction p/q (where p, q are integers and q > 0), then (cos θ + i sin θ)^(p/q) has ______ distinct values.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "q",
        "B": "p",
        "C": "p + q",
        "D": "Infinite"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "If z = r(cos θ + i sin θ), then zⁿ = ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "rⁿ (cos nθ + i sin nθ)",
        "B": "r (cos nθ + i sin nθ)",
        "C": "rⁿ (cos θ + i sin θ)",
        "D": "r (cos θ + i sin θ)ⁿ"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "De Moivre's Theorem is heavily used to derive identities by expanding (cos θ + i sin θ)ⁿ using ______ Theorem.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Binomial",
        "B": "Taylor's",
        "C": "Maclaurin's",
        "D": "Pascal's"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 4,
      "question": "To find the q distinct roots of z^(1/q), we apply De Moivre's. The arguments are ______ for k = 0, 1, ..., q-1.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(θ + 2kπ) / q",
        "B": "q(θ + 2kπ)",
        "C": "(θ + kπ) / q",
        "D": "(θ - 2kπ) / q"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 5,
      "question": "The n distinct roots of zⁿ = 1 lie on the unit circle in the complex plane and form a regular ______.",
