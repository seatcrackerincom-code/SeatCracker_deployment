      "id": 1,
      "question": "The direction cosines l, m, n of a vector satisfy ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "l² + m² + n² = 1",
        "B": "l + m + n = 1",
        "C": "l² + m² + n² = 0",
        "D": "l + m + n = 0"
      },
      "answer": "A",
      "pyq": false
    },
    {
