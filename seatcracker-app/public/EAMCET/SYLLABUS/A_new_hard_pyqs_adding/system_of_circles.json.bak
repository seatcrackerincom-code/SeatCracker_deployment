  "questions": [
    {
      "id": 1,
      "question": "The diagram show two intersecting circles with centers C1, C2 and radii r1, r2. The angle θ between them satisfies cos θ = ______.",
      "difficulty": "Medium",
      "hasDiagram": true,
      "diagram_description": "Two circles intersecting at point P. Triangle C1-P-C2 is formed with sides r1, r2, and d (distance between centers).",
      "options": {
        "A": "(r₁² + r₂² - d²) / (2 r₁ r₂)",
        "B": "(d² - r₁² - r₂²) / (2 r₁ r₂)",
        "C": "(r₁ + r₂)² / d²",
        "D": "d² / (r₁² + r₂²)"
      },
      "answer": "A"
    },
    {
      "id": 2,
      "question": "The condition for two circles x² + y² + 2gx + 2fy + c = 0 and x² + y² + 2g'x + 2f'y + c' = 0 to intersect orthogonally is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "2gg' + 2ff' = c + c'",
        "B": "gg' + ff' = c + c'",
        "C": "2gg' - 2ff' = c - c'",
        "D": "g² + f² - c = g'² + f'² - c'"
      },
      "answer": "A"
    },
    {
      "id": 3,
      "question": "If two circles intersect orthogonally, the tangent to one circle at the point of intersection passes through the ______ of the other circle.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Center",
        "B": "Focus",
        "C": "Vertex",
        "D": "Pole"
      },
      "answer": "A"
    },
    {
      "id": 4,
      "question": "The radical axis of two circles is always ______ to the line joining their centers.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Perpendicular",
        "B": "Parallel",
        "C": "Coincident",
        "D": "At 45°"
      },
      "answer": "A"
    },
    {
      "id": 5,
      "question": "If two circles intersect at real points, the radical axis is the line containing their ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Common chord",
        "B": "Centers",
        "C": "Directrices",
        "D": "Poles"
      },
      "answer": "A"
    },
    {
      "id": 6,
      "question": "If two circles touch each other (internally or externally), the radical axis is the ______ at the point of contact.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Common tangent",
        "B": "Common normal",
        "C": "Line of centers",
        "D": "Director circle locus"
      },
      "answer": "A"
    },
    {
      "id": 7,
      "question": "If a circle cuts three given circles orthogonally, its center is the ______ of the three given circles.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Radical center",
        "B": "Incenter",
        "C": "Circumcenter",
        "D": "Orthocenter"
      },
      "answer": "A"
    },
    {
      "id": 8,
      "question": "The radius of the circle which cuts three given circles orthogonally is equal to the length of the ______ from the radical center to any of the circles.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Tangent",
        "B": "Secant",
        "C": "Normal",
        "D": "Chord"
      },
      "answer": "A"
    },
    {
      "id": 9,
      "question": "A system of circles is said to be coaxial if every pair of circles in the system has the same ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Radical axis",
        "B": "Center",
        "C": "Radius",
        "D": "Tangent"
      },
      "answer": "A"
    },
    {
      "id": 10,
      "question": "The centers of all circles forming a coaxial system lie on a ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "Straight line",
        "B": "Circle",
        "C": "Parabola",
        "D": "Radical axis"
      },
      "answer": "A"
    },
    {
      "id": 11,
      "question": "The simplest form of the equation of a coaxial system is x² + y² + 2gx + c = 0, where ______ varies and ______ is constant.",
      "difficulty": "Hard",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "g varies, c is constant",
        "B": "c varies, g is constant",
