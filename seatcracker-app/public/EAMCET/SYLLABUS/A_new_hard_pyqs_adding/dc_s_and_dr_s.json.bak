  "questions": [
    {
      "id": 1,
      "question": "From the identity l² + m² + n² = 1, substituting sines instead of cosines gives sin² α + sin² β + sin² γ = ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "2",
        "B": "1",
        "C": "3",
        "D": "0"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "If a, b, c are the DRs of a line, the DCs are derived as l = ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "± a / √(a² + b² + c²)",
        "B": "a / (a + b + c)",
        "C": "a² / (a² + b² + c²)",
        "D": "√(a² + b² + c²) / a"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 3,
      "question": "If a line passes through two points P(x₁, y₁, z₁) and Q(x₂, y₂, z₂), its Direction Ratios are proportional to ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(x₂ - x₁), (y₂ - y₁), (z₂ - z₁)",
        "B": "(x₂ + x₁), (y₂ + y₁), (z₂ + z₁)",
        "C": "(x₁ x₂), (y₁ y₂), (z₁ z₂)",
        "D": "(x₂/x₁), (y₂/y₁), (z₂/z₁)"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 4,
      "question": "Direction Cosines of the line joining P and Q are the DRs divided by ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "PQ (The distance between P and Q)",
