      "id": 1,
      "question": "The parametric equations of y² = 4ax are ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "x = at², y = 2at",
        "B": "x = 2at, y = at²",
        "C": "x = t, y = t²",
        "D": "x = a cos t, y = a sin t"
      },
      "answer": "A",
      "pyq": false
    },
    {
      "id": 2,
      "question": "Equation of the tangent at (at², 2at) on y² = 4ax is ______.",
      "difficulty": "Medium",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "ty = x + at²",
        "B": "ty = x - at²",
        "C": "y = tx + at²",
        "D": "y = t²x + at"
      },
      "answer": "A",
      "pyq": false
    },
