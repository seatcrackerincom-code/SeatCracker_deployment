    { "id": 9, "question": "Earthworm is an example of ______.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "Detritivore", "B": "Consumer", "C": "Producer", "D": "None" }, "answer": "A", "pyq": true },
    { "id": 10, "question": "The process where water-soluble inorganic nutrients go down into soil horizon and get precipitated as unavailable salts is ______.", "difficulty": "medium", "hasDiagram": false, "diagram_description": "", "options": { "A": "Leaching", "B": "Fragmentation", "C": "Catabolism", "D": "None" }, "answer": "A", "pyq": true },
