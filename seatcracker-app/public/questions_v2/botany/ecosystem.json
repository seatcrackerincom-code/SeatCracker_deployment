    { "id": 3, "question": "Vertical distribution of different species occupying different levels in an ecosystem is ______.", "difficulty": "medium", "hasDiagram": false, "diagram_description": "", "options": { "A": "Stratification", "B": "Succession", "C": "Fragmentation", "D": "None" }, "answer": "A", "pyq": true },
    { "id": 4, "question": "The rate of biomass production is called ______.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "Productivity", "B": "Consumption", "C": "Respiration", "D": "None" }, "answer": "A", "pyq": true },
