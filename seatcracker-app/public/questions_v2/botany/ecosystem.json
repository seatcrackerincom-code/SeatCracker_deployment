    { "id": 21, "question": "Lindeman's rule states that only ______ percent of energy is transferred to the next trophic level.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "10", "B": "50", "C": "100", "D": "5" }, "answer": "A", "pyq": true },
    { "id": 22, "question": "Pyramid of energy is ______.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "Always upright", "B": "Always inverted", "C": "Both", "D": "None" }, "answer": "A", "pyq": true },
