    { "id": 1, "question": "An ecosystem is a functional unit of nature where living organisms interact among themselves and with surroundings.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "True", "B": "False", "C": "None", "D": "None" }, "answer": "A", "pyq": true },
