    { "id": 34, "question": "Sedimentary nutrient cycles include ______ and ______.", "difficulty": "medium", "hasDiagram": false, "diagram_description": "", "options": { "A": "Phosphorus, Calcium", "B": "Nitrogen", "C": "Water", "D": "None" }, "answer": "A", "pyq": false },
