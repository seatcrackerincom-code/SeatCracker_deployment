    { "id": 12, "question": "Decomposition rate is slower if detritus is rich in ______ and ______.", "difficulty": "hard", "hasDiagram": false, "diagram_description": "", "options": { "A": "Lignin, Chitin", "B": "Nitrogen", "C": "Sugar", "D": "None" }, "answer": "A", "pyq": true },
    { "id": 13, "question": "Warmer and moist environment favors decomposition.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "True", "B": "False", "C": "None", "D": "None" }, "answer": "A", "pyq": true },
    { "id": 14, "question": "Energy flow in an ecosystem is ______.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "Unidirectional", "B": "Bidirectional", "C": "Cyclic", "D": "None" }, "answer": "A", "pyq": true },
    { "id": 15, "question": "Plant Capture only ______ percent of PAR (Photosynthetically Active Radiation).", "difficulty": "hard", "hasDiagram": false, "diagram_description": "", "options": { "A": "2-10", "B": "50", "C": "1", "D": "100" }, "answer": "A", "pyq": true },
    { "id": 16, "question": "Detritus Food Chain (DFC) begins with ______.", "difficulty": "easy", "hasDiagram": false, "diagram_description": "", "options": { "A": "Dead organic matter", "B": "Green plants", "C": "Consumers", "D": "None" }, "answer": "A", "pyq": true },
