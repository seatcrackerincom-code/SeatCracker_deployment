    {
      "id": 1,
      "question": "The standard equation of a circle with center (h, k) and radius r is ______.",
      "difficulty": "easy",
      "hasDiagram": false,
      "diagram_description": "",
      "options": {
        "A": "(x-h)² + (y-k)² = r²",
        "B": "(x+h)² + (y+k)² = r²",
        "C": "x² + y² = r²",
        "D": "(x-h)² - (y-k)² = r²"
      },
      "answer": "A"
    },
    {
      "id": 2,
      "question": "In the general equation of a circle x² + y² + 2gx + 2fy + c = 0, the center is ______.",
